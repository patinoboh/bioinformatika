    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "debug1",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}/project",
            // "args": ["--input", "${workspaceFolder}/data/data.csv"],
            "console": "integratedTerminal",
            // change the path from the workspace folder to the path of your data file
        }
    
    ]
